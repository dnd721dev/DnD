# LiveKit — same values as the main app's env
LIVEKIT_WS_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=secretxxxxxxxx

# Supabase — service role key (NOT the anon key)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Storage bucket for recordings (same as RECORDING_S3_BUCKET in the app)
RECORDING_BUCKET=recordings

# Optional: app URL so the worker can kick transcription after upload
APP_BASE_URL=https://your-app.vercel.app

# Optional: job poll interval
POLL_INTERVAL_MS=3000
