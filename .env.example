# ============================================================
# DND721 — required environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public URL of your Supabase project (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co

# Publishable (anon) key — used by the client-side Supabase client
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Service role key — SERVER ONLY, never expose to browser
# Used by supabaseAdmin() in API routes to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# JWT secret — used to verify Supabase session tokens server-side
SUPABASE_JWT_SECRET=...


# ── LiveKit ───────────────────────────────────────────────────
# Found in: LiveKit Cloud dashboard → your project → settings

# WebSocket URL for the LiveKit room server (client + server)
NEXT_PUBLIC_LIVEKIT_WS_URL=wss://<project>.livekit.cloud

# Same URL — kept as a second var for legacy compat
NEXT_PUBLIC_LIVEKIT_URL=wss://<project>.livekit.cloud

# API key and secret — SERVER ONLY (used in /api/livekit-token and recording routes)
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...


# ── WalletConnect / Web3Modal ─────────────────────────────────
# Create a project at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...


# ── Base L2 / NFT ─────────────────────────────────────────────
# Chain IDs: 8453 = Base mainnet, 84532 = Base Sepolia testnet
NEXT_PUBLIC_CHAIN_ID=8453

# Comma-separated ERC-721 contract addresses for character NFTs
NEXT_PUBLIC_NFT_CONTRACTS=0x...

# OpenSea API key — used by /api/nft to read NFT metadata
# Get one at https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=...


# ── App identity ──────────────────────────────────────────────
# Your deployed URL (used for WalletConnect deep-link callback)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

NEXT_PUBLIC_APP_NAME=DND721

# Treasury wallet that receives sponsored-monster payments
NEXT_PUBLIC_TREASURY_WALLET=0x...


# ── Session recording (S3-compatible storage) ─────────────────
# You can use Supabase Storage S3 API, AWS S3, R2, etc.
# If unset, the recording feature returns a 503 but everything else works.

RECORDING_S3_BUCKET=recordings
RECORDING_S3_REGION=us-east-1
RECORDING_S3_ACCESS_KEY=...
RECORDING_S3_SECRET=...

# Leave blank for AWS S3; set to your provider's endpoint for Supabase/R2/MinIO
RECORDING_S3_ENDPOINT=https://<project>.supabase.co/storage/v1/s3

# Public base URL for serving completed recording files
RECORDING_S3_PUBLIC_BASE_URL=https://<project>.supabase.co/storage/v1/object/public/recordings
