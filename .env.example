# ============================================================
# DND721 — required environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Public URL of your Supabase project (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co

# Publishable (anon) key — used by the client-side Supabase client
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Service role key — SERVER ONLY, never expose to browser
# Used by supabaseAdmin() in API routes to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# JWT secret — used to verify Supabase session tokens server-side
SUPABASE_JWT_SECRET=...


# ── LiveKit ───────────────────────────────────────────────────
# Found in: LiveKit Cloud dashboard → your project → settings

# WebSocket URL for the LiveKit room server (client + server)
NEXT_PUBLIC_LIVEKIT_WS_URL=wss://<project>.livekit.cloud

# Same URL — kept as a second var for legacy compat
NEXT_PUBLIC_LIVEKIT_URL=wss://<project>.livekit.cloud

# API key and secret — SERVER ONLY (used in /api/livekit-token and recording routes)
LIVEKIT_API_KEY=API...
LIVEKIT_API_SECRET=...


# ── WalletConnect / Web3Modal ─────────────────────────────────
# Create a project at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=...


# ── Base L2 / NFT ─────────────────────────────────────────────
# Chain IDs: 8453 = Base mainnet, 84532 = Base Sepolia testnet
NEXT_PUBLIC_CHAIN_ID=8453

# Comma-separated ERC-721 contract addresses for character NFTs
NEXT_PUBLIC_NFT_CONTRACTS=0x...

# OpenSea API key — used by /api/nft to read NFT metadata
# Get one at https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=...


# ── App identity ──────────────────────────────────────────────
# Your deployed URL (used for WalletConnect deep-link callback)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

NEXT_PUBLIC_APP_NAME=DND721

# Live Telegram feed on /community (read-only mirror of the DND721 group).
# 1. Create a bot with @BotFather → token below.
# 2. Add it to the group; @BotFather /setprivacy → Disable (so it sees all msgs).
# 3. Get the group chat id (e.g. @getidsbot) → TELEGRAM_CHAT_ID (e.g. -1001234567890).
# 4. Pick any random string for TELEGRAM_WEBHOOK_SECRET.
# 5. Register once: curl "https://api.telegram.org/bot<token>/setWebhook?url=https://<app>/api/telegram/webhook&secret_token=<secret>"
# All three are server-only (no NEXT_PUBLIC_ prefix — never exposed to the browser).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Treasury / marketing wallet that receives shop payments on Base
# This is the DND721 marketing wallet address
NEXT_PUBLIC_TREASURY_WALLET=0x03477126328150f175f4e9919ebed7Ef9eFB91a3


# ── Session recording (S3-compatible storage) ─────────────────
# You can use Supabase Storage S3 API, AWS S3, R2, etc.
# If unset, the recording feature returns a 503 but everything else works.

RECORDING_S3_BUCKET=recordings
RECORDING_S3_REGION=us-east-1
RECORDING_S3_ACCESS_KEY=...
RECORDING_S3_SECRET=...

# Leave blank for AWS S3; set to your provider's endpoint for Supabase/R2/MinIO
RECORDING_S3_ENDPOINT=https://<project>.supabase.co/storage/v1/s3

# Public base URL for serving completed recording files
RECORDING_S3_PUBLIC_BASE_URL=https://<project>.supabase.co/storage/v1/object/public/recordings


# ── Shop ──────────────────────────────────────────────────────
# Base RPC endpoint used server-side to verify on-chain purchases
# Use https://mainnet.base.org (free) or an Alchemy/Infura Base endpoint
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# Secret used to authenticate the Vercel Cron daily shop refresh
# Generate with: openssl rand -hex 32
CRON_SECRET=...

# Fallback DND721/USD price used when DexScreener has no data for the token.
# Set this to the current market price. The shop will still work without it
# (defaults to $0.10) but set it for accuracy.
DND721_PRICE_USD_FALLBACK=0.01

# ─── Marketplace NFT escrow (auto-delivery via MarketEscrow.sol) ─────────────
# NFT sale/rental listings auto-deliver the NFT to the buyer the instant their
# payment verifies, with NO action required from the seller. This works via
# contracts/MarketEscrow.sol: sellers approve() that CONTRACT (not a wallet)
# when listing, and only the registered relayer key can call its single
# executeSale() function — which reverts unless the token was actually
# approved. Approving a verified, source-published contract like this is what
# avoids the "untrusted EOA" warning wallets show for approving a raw address.
#
# Setup:
#   1. Deploy contracts/MarketEscrow.sol (e.g. via Remix) to Base, passing
#      your relayer wallet's address as the constructor arg.
#   2. Verify the source on Basescan (Sourcify/Basescan "Verify Contract").
#   3. Set the two vars below. If unset, sales fall back to a manual
#      "Send NFT to buyer" step for sellers — nothing breaks either way.
NEXT_PUBLIC_MARKET_ESCROW_ADDRESS=0x...   # the DEPLOYED CONTRACT address
MARKET_ESCROW_PRIVATE_KEY=0x...          # the relayer wallet's key (server-only)
